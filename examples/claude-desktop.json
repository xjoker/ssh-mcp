{
  "_comment": [
    "Claude Desktop has no MCP-management CLI yet, so this snippet must be",
    "pasted manually into claude_desktop_config.json:",
    "  macOS  : ~/Library/Application Support/Claude/claude_desktop_config.json",
    "  Windows: %APPDATA%\\Claude\\claude_desktop_config.json",
    "  Linux  : ~/.config/Claude/claude_desktop_config.json",
    "",
    "Replace the command path with the actual install path printed by",
    "'mcp-ssh-bridge install claude-desktop' (defaults to",
    "~/.local/bin/mcp-ssh-bridge on macOS/Linux,",
    "%LOCALAPPDATA%\\Programs\\mcp-ssh-bridge\\mcp-ssh-bridge.exe on Windows).",
    "",
    "WARNING: Do NOT add autoApprove for any of mcp-ssh-bridge tools."
  ],
  "mcpServers": {
    "ssh-bridge": {
      "command": "/Users/<you>/.local/bin/mcp-ssh-bridge",
      "args": []
    }
  }
}
